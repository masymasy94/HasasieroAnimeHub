<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0b1622" />
            <size android:width="320dp" android:height="180dp" />
        </shape>
    </item>
    <!-- Accent left bar -->
    <item android:right="312dp">
        <shape android:shape="rectangle">
            <solid android:color="#3db4f2" />
        </shape>
    </item>
    <!-- Accent bottom bar -->
    <item android:top="174dp">
        <shape android:shape="rectangle">
            <solid android:color="#3db4f2" />
        </shape>
    </item>
    <!-- Center icon -->
    <item
        android:drawable="@drawable/ic_launcher"
        android:gravity="center"
        android:width="80dp"
        android:height="80dp" />
</layer-list>
